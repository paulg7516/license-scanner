# =============================================================
# License Watchdog UI - Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to source control
# =============================================================

# Azure AD Configuration
# Get these from Azure Portal > App Registrations > Your App
AZURE_CLIENT_ID=your-app-client-id-here
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_SECRET=your-app-client-secret-here
REDIRECT_URI=http://localhost:8501

# Encryption Key for storing tokens securely
# Generate one by running: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Database path (SQLite)
DATABASE_PATH=watchdog.db

# AI Summary (Claude API)
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
